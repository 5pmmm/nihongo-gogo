rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net - Deny by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidAssistantQuery(data) {
      return data.keys().hasAll(['syncKey', 'query', 'responseJson', 'timestamp', 'createdAt'])
        && data.keys().size() == 5
        && data.syncKey is string
        && data.syncKey.size() <= 100
        && data.query is string
        && data.query.size() <= 2000
        && data.responseJson is string
        && data.responseJson.size() <= 100000
        && (data.timestamp is int || data.timestamp is float)
        && data.createdAt == request.time;
    }

    // Assistant Queries collection rules
    match /assistant_queries/{queryId} {
      allow create: if isValidAssistantQuery(request.resource.data) && isValidId(queryId);
      allow get, list: if resource.data.syncKey != null && resource.data.syncKey.size() <= 100;
      allow update, delete: if false;
    }
  }
}
